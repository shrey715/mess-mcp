{
    "name": "ferdium-orchestrator",
    "version": "1.0.0",
    "description": "A high-performance Ferdium-like applet orchestrator",
    "main": "src/main/main.js",
    "scripts": {
        "start": "electron .",
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:demo\" \"wait-on http://localhost:5173 && electron . --no-sandbox\"",
        "dev:renderer": "vite",
        "dev:demo": "node src/demo-server.js",
        "build": "vite build && electron-builder",
        "lint": "eslint src/"
    },
    "keywords": [
        "electron",
        "orchestrator",
        "applet",
        "ferdium"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "concurrently": "^8.2.2",
        "electron": "^28.1.0",
        "electron-builder": "^24.9.1",
        "eslint": "^8.56.0",
        "postcss": "^8.4.33",
        "tailwindcss": "^3.4.1",
        "vite": "^5.0.12",
        "wait-on": "^7.2.0"
    },
    "dependencies": {
        "electron-store": "^8.1.0",
        "lucide-react": "^0.563.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    }
}
